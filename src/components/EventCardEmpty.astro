<a
    class="meetup-events__card group block p-[clamp(1.5rem,calc(0.67rem+4.17vw),4rem)] border border-white/10"
    aria-label="No upcoming events — visit us on Meetup (opens in new tab)"
    data-scroll="up"
    href="https://meetup.com/algoatx"
    rel="noopener noreferrer"
    target="_blank"
>
    <div class="flex flex-col gap-[clamp(2rem,calc(1rem+5vw),3rem)] md:flex-row md:items-center">
        <div class="flex flex-col items-center shrink-0 border-white/10 text-center md:w-[clamp(6rem,calc(4.67rem+6.67vw),10rem)] md:border-r md:pr-[clamp(1rem,calc(0.33rem+3.33vw),3rem)]">
            <span class="meetup-events__day font-bold text-[clamp(2.5rem,calc(1.83rem+3.33vw),4.5rem)] leading-tight">
                —
            </span>
        </div>
        <div class="flex-1 min-w-0 space-y-[clamp(2rem,calc(1rem+5vw),3rem)] text-center md:text-left md:space-y-[clamp(0.75rem,calc(0.42rem+1.67vw),1.5rem)]">
            <h3 class="meetup-events__name text-center font-semibold leading-snug text-[clamp(1.25rem,calc(0.92rem+1.67vw),2.25rem)] text-zinc-200 md:text-left">
                No upcoming events
            </h3>
        </div>
        <span class="meetup-events__arrow hidden shrink-0 text-[clamp(1rem,calc(0.67rem+1.67vw),2rem)] text-zinc-200/30 select-none transition-[color,transform] duration-300 md:block" aria-hidden="true">→</span>
    </div>
</a>
