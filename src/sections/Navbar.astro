---
import LeetCodeIcon from '@components/LeetCodeIcon.astro';
import LogoIcon from '@components/LogoIcon.astro';
import MeetupIcon from '@components/MeetupIcon.astro';
import SearchIcon from '@components/SearchIcon.astro';
---

<nav class="navbar fixed top-0 z-50 w-full border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-md">
    <div class="flex items-center justify-between max-w-7xl mx-auto px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(0.75rem,calc(0.5rem+1.25vw),1.5rem)]">
        <a
            class="navbar__logo transition-opacity duration-300"
            aria-label="Home"
            href="/"
        >
            <LogoIcon />
        </a>
        <div class="navbar__search relative flex-1 max-w-xl mx-[clamp(1rem,calc(0.67rem+1.67vw),2rem)]">
            <input
                id="search-input"
                class="navbar__input w-full px-[clamp(0.75rem,calc(0.5rem+1.25vw),1.5rem)] py-[clamp(0.5rem,calc(0.33rem+0.83vw),1rem)] pl-[clamp(2rem,calc(1.67rem+1.67vw),3rem)] rounded-lg border border-zinc-800 font-mono text-[clamp(0.875rem,calc(0.79rem+0.42vw),1.125rem)] bg-zinc-900/50 text-zinc-300 placeholder-zinc-600 outline-none transition-colors duration-300"
                aria-autocomplete="list"
                aria-controls="search-results"
                aria-expanded="false"
                aria-label="Search problems"
                autocomplete="off"
                placeholder="Search..."
                role="combobox"
                type="text"
            />
            <SearchIcon />
            <kbd class="hidden absolute right-3.5 top-1/2 px-2 py-1 rounded border border-zinc-700 font-mono text-xs text-zinc-600 -translate-y-1/2 pointer-events-none select-none sm:inline-block" aria-hidden="true">/</kbd>
            <div
                id="search-results"
                class="navbar__results absolute left-0 right-0 top-full mt-4 rounded-lg border border-zinc-800 bg-zinc-900 overflow-y-auto opacity-0 backdrop-blur-md pointer-events-none transition-opacity duration-300"
                role="listbox"
            >
            </div>
        </div>
        <div class="flex items-center gap-[clamp(1rem,calc(0.67rem+1.67vw),2rem)]">
            <a
                class="transition-opacity duration-300 hover:opacity-80"
                aria-label="Meetup (opens in new tab)"
                href="https://meetup.com/algoatx"
                rel="noopener noreferrer"
                target="_blank"
            >
                <MeetupIcon />
            </a>
            <a
                class="transition-opacity duration-300 hover:opacity-80"
                aria-label="LeetCode (opens in new tab)"
                href="https://leetcode.com/u/aephonics"
                rel="noopener noreferrer"
                target="_blank"
            >
                <LeetCodeIcon />
            </a>
        </div>
    </div>
</nav>
<div class="h-[clamp(3rem,calc(1.33rem+8.33vw),8rem)]"></div>

<style is:global>
    .navbar__badge {
        font-size: clamp(0.5rem, calc(0.46rem + 0.21vw), 0.625rem);
    }

    .navbar__result-text {
        font-size: clamp(0.75rem, calc(0.67rem + 0.42vw), 1rem);
    }

    .navbar__results {
        max-height: calc((clamp(0.75rem, calc(0.67rem + 0.42vw), 1rem) * 1.5 + 1.25rem) * 8);
    }

    .navbar__input:focus {
        background-color: rgba(var(--rgb-zinc-900), 0.8);
        border-color: rgba(var(--color-indigo), 0.3);
    }

    .navbar__input:hover {
        background-color: rgba(var(--rgb-zinc-900), 0.8);
        border-color: rgb(var(--rgb-zinc-600));
    }

    .navbar__logo:hover {
        opacity: 0.8;
    }

    .navbar__result[aria-selected="true"],
    .navbar__result[aria-selected="true"]:hover {
        background-color: rgba(var(--rgb-zinc-600), 0.3);
    }

    .navbar__results::-webkit-scrollbar {
        width: 4px;
    }

    .navbar__results::-webkit-scrollbar-thumb {
        background: rgb(var(--rgb-zinc-600));
        border-radius: 2px;
    }

    .navbar__results::-webkit-scrollbar-track {
        background: transparent;
    }
</style>

<script>
    interface SearchEntry {
        d: string;
        i: string;
        t: string;
    }

    const BADGE_STYLES: Record<string, { classes: string; label: string }> = {
        ds: { classes: 'bg-indigo-500/15 text-indigo-400', label: 'DS' },
        e: { classes: 'bg-emerald-500/15 text-emerald-400', label: 'easy' },
        h: { classes: 'bg-red-500/15 text-red-400', label: 'hard' },
        m: { classes: 'bg-amber-500/15 text-amber-400', label: 'medium' },
    };

    const MAX_RESULTS = 20;

    let activeIndex = -1;
    let cleanup: (() => void) | null = null;
    let pointerInResults = false;
    let searchIndex: SearchEntry[] | null = null;

    function escapeHtml(text: string): string {
        return text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    async function loadIndex(): Promise<SearchEntry[]> {
        if (searchIndex) return searchIndex;
        const response = await fetch('/api/search.json');
        searchIndex = await response.json();
        return searchIndex!;
    }

    function renderBadge(type: string): string {
        const badge = BADGE_STYLES[type] ?? BADGE_STYLES.h;
        return `<span class="navbar__badge hidden px-2 py-0.5 rounded-full uppercase tracking-wider sm:inline-block ${badge.classes}">${badge.label}</span>`;
    }

    function sortResults(a: SearchEntry, b: SearchEntry): number {
        if (a.d === 'ds' && b.d !== 'ds') return -1;
        if (a.d !== 'ds' && b.d === 'ds') return 1;
        if (a.d !== 'ds' && b.d !== 'ds') return parseInt(a.i) - parseInt(b.i);
        return a.t.localeCompare(b.t);
    }

    function initSearch() {
        cleanup?.();

        const input = document.getElementById('search-input') as HTMLInputElement;
        const results = document.getElementById('search-results') as HTMLElement;
        if (!input || !results) return;

        function hideResults() {
            input.setAttribute('aria-expanded', 'false');
            input.removeAttribute('aria-activedescendant');
            activeIndex = -1;
            pointerInResults = false;
            toggleResults(false);
        }

        function onDocClick(e: MouseEvent) {
            const target = e.target as Node;

            if (!input.contains(target) && !results.contains(target)) {
                hideResults();
            }
        }

        function onDocKeydown(e: KeyboardEvent) {
            if (e.key === '/') {
                e.preventDefault();
                if (document.activeElement === input) {
                    input.blur();
                    hideResults();
                } else {
                    input.focus();
                }
                return;
            }

            if (e.key === 'Escape') {
                input.value = '';
                hideResults();
                input.blur();
            }
        }

        function onFocus() {
            if (input.value) search(input.value);
        }

        function onInput(e: Event) {
            search((e.target as HTMLInputElement).value);
        }

        function onInputKeydown(e: KeyboardEvent) {
            const items = results.querySelectorAll<HTMLAnchorElement>('.navbar__result');
            if (!items.length) return;

            if (e.key === 'ArrowDown') {
                e.preventDefault();
                const next = activeIndex < items.length - 1 ? activeIndex + 1 : 0;
                setActiveResult(next);
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                const prev = activeIndex > 0 ? activeIndex - 1 : items.length - 1;
                setActiveResult(prev);
            } else if (e.key === 'Enter' && activeIndex >= 0) {
                e.preventDefault();
                items[activeIndex].click();
            }
        }

        function onResultsPointerLeave() {
            pointerInResults = false;
        }

        function renderResults(matches: SearchEntry[]) {
            if (matches.length === 0) {
                activeIndex = -1;
                results.innerHTML = '<div class="navbar__result-text px-4 py-2.5 font-mono text-zinc-600">No results</div>';
            } else {
                results.innerHTML = matches.slice(0, MAX_RESULTS).map((entry, i) =>
                    `<a id="search-result-${i}" class="navbar__result navbar__result-text flex items-center justify-between px-4 py-2.5 gap-3 text-zinc-300 transition-colors duration-100" href="/${entry.i}" role="option"><span class="truncate">${escapeHtml(entry.t)}</span>${renderBadge(entry.d)}</a>`,
                ).join('');

                results.querySelectorAll<HTMLAnchorElement>('.navbar__result').forEach((item, i) => {
                    item.addEventListener('pointerenter', () => {
                        pointerInResults = true;
                        setActiveResult(i);
                    });
                });

                if (!pointerInResults) setActiveResult(0);
            }
        }

        async function search(query: string) {
            if (!query) {
                hideResults();
                return;
            }

            const index = await loadIndex();
            const normalizedQuery = query.toLowerCase();
            const matches = index
                .filter(entry => entry.t.toLowerCase().includes(normalizedQuery) || entry.i === normalizedQuery)
                .sort(sortResults);
            renderResults(matches);
            showResults();
        }

        function setActiveResult(index: number) {
            const items = results.querySelectorAll<HTMLAnchorElement>('.navbar__result');
            items.forEach(item => item.removeAttribute('aria-selected'));
            activeIndex = index;

            if (index >= 0 && index < items.length) {
                const item = items[index];
                item.setAttribute('aria-selected', 'true');
                item.scrollIntoView({ block: 'nearest' });
                input.setAttribute('aria-activedescendant', item.id);
            } else {
                input.removeAttribute('aria-activedescendant');
            }
        }

        function showResults() {
            input.setAttribute('aria-expanded', 'true');
            toggleResults(true);
        }

        function teardown() {
            input.removeEventListener('input', onInput);
            input.removeEventListener('focus', onFocus);
            input.removeEventListener('keydown', onInputKeydown);
            results.removeEventListener('pointerleave', onResultsPointerLeave);
            document.removeEventListener('click', onDocClick);
            document.removeEventListener('keydown', onDocKeydown);
        }

        function toggleResults(visible: boolean) {
            results.classList.toggle('opacity-100', visible);
            results.classList.toggle('pointer-events-auto', visible);
            results.classList.toggle('opacity-0', !visible);
            results.classList.toggle('pointer-events-none', !visible);
        }

        loadIndex();
        input.addEventListener('input', onInput);
        input.addEventListener('focus', onFocus);
        input.addEventListener('keydown', onInputKeydown);
        results.addEventListener('pointerleave', onResultsPointerLeave);
        document.addEventListener('click', onDocClick);
        document.addEventListener('keydown', onDocKeydown);
        input.dataset.ready = '';
        cleanup = teardown;
    }

    document.addEventListener('astro:page-load', initSearch);
</script>
