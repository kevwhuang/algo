---
import LeetCodeIcon from '@components/LeetCodeIcon.astro';
import LogoIcon from '@components/LogoIcon.astro';
import MeetupIcon from '@components/MeetupIcon.astro';
import SearchIcon from '@components/SearchIcon.astro';
---

<nav class="navbar fixed top-0 z-50 w-full border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-md">
    <div class="flex items-center justify-between max-w-7xl mx-auto px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(0.75rem,calc(0.5rem+1.25vw),1.5rem)]">
        <a
            class="navbar__logo transition-opacity duration-300"
            aria-label="Home"
            href="/"
        >
            <LogoIcon />
        </a>
        <div class="navbar__search relative flex-1 max-w-xl mx-[clamp(1rem,calc(0.67rem+1.67vw),2rem)]">
            <input
                id="search-input"
                class="navbar__input w-full px-[clamp(0.75rem,calc(0.5rem+1.25vw),1.5rem)] py-[clamp(0.5rem,calc(0.33rem+0.83vw),1rem)] pl-[clamp(2rem,calc(1.5rem+2.5vw),3rem)] rounded-lg border border-zinc-800 font-mono text-[clamp(0.875rem,calc(0.79rem+0.42vw),1.125rem)] bg-zinc-900/50 text-zinc-300 placeholder-zinc-600 outline-none transition-colors duration-300"
                aria-label="Search problems"
                autocomplete="off"
                placeholder="Search..."
                type="text"
            />
            <SearchIcon />
            <kbd class="hidden absolute right-3.5 top-1/2 px-2 py-1 rounded border border-zinc-700 font-mono text-xs text-zinc-600 -translate-y-1/2 pointer-events-none select-none sm:inline-block">/</kbd>
            <div
                id="search-results"
                class="navbar__results absolute left-0 right-0 top-full mt-4 rounded-lg border border-zinc-800 bg-zinc-900 overflow-y-auto opacity-0 backdrop-blur-md pointer-events-none transition-opacity duration-300"
            >
            </div>
        </div>
        <div class="flex items-center gap-[clamp(1rem,calc(0.67rem+1.67vw),2rem)]">
            <a
                class="transition-opacity duration-300 hover:opacity-80"
                aria-label="Meetup (opens in new tab)"
                href="https://meetup.com/algoatx"
                rel="noopener noreferrer"
                target="_blank"
            >
                <MeetupIcon />
            </a>
            <a
                class="transition-opacity duration-300 hover:opacity-80"
                aria-label="LeetCode (opens in new tab)"
                href="https://leetcode.com/u/aephonics"
                rel="noopener noreferrer"
                target="_blank"
            >
                <LeetCodeIcon />
            </a>
        </div>
    </div>
</nav>
<div class="h-[clamp(3rem,calc(1.33rem+8.33vw),8rem)]"></div>

<style is:global>
    .navbar__badge {
        font-size: clamp(0.5rem, calc(0.42rem + 0.42vw), 0.625rem);
    }

    .navbar__result-text {
        font-size: clamp(0.75rem, calc(0.67rem + 0.42vw), 1rem);
    }

    .navbar__results {
        max-height: calc((clamp(0.75rem, calc(0.67rem + 0.42vw), 1rem) * 1.5 + 1.25rem) * 8);
    }

    .navbar__logo:hover {
        opacity: 0.8;
    }

    .navbar__input:focus {
        background-color: rgba(var(--color-zinc-900), 0.8);
        border-color: rgba(var(--color-indigo), 0.3);
    }

    .navbar__input:hover {
        background-color: rgba(var(--color-zinc-900), 0.8);
        border-color: rgb(var(--color-zinc-600));
    }

    .navbar__results::-webkit-scrollbar {
        width: 4px;
    }

    .navbar__results::-webkit-scrollbar-thumb {
        background: rgb(var(--color-zinc-600));
        border-radius: 2px;
    }

    .navbar__results::-webkit-scrollbar-track {
        background: transparent;
    }
</style>

<script>
    interface SearchEntry {
        d: string;
        i: string;
        t: string;
    }

    const BADGE_STYLES: Record<string, { classes: string; label: string }> = {
        ds: { classes: 'bg-indigo-500/15 text-indigo-400', label: 'DS' },
        e: { classes: 'bg-emerald-500/15 text-emerald-400', label: 'easy' },
        h: { classes: 'bg-red-500/15 text-red-400', label: 'hard' },
        m: { classes: 'bg-amber-500/15 text-amber-400', label: 'medium' },
    };

    const MAX_RESULTS = 20;

    let initialized = false;
    let searchIndex: SearchEntry[] | null = null;

    function escapeHtml(str: string): string {
        return str
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    async function loadIndex(): Promise<SearchEntry[]> {
        if (searchIndex) return searchIndex;
        const res = await fetch('/api/search.json');
        searchIndex = await res.json();
        return searchIndex!;
    }

    function renderBadge(type: string): string {
        const badge = BADGE_STYLES[type] ?? BADGE_STYLES.h;
        return `<span class="navbar__badge hidden px-2 py-0.5 rounded-full uppercase tracking-wider sm:inline-block ${badge.classes}">${badge.label}</span>`;
    }

    function renderResults(el: HTMLElement, matches: SearchEntry[]) {
        if (matches.length === 0) {
            el.innerHTML = '<div class="navbar__result-text px-4 py-2.5 font-mono text-zinc-600">No results</div>';
        } else {
            el.innerHTML = matches.slice(0, MAX_RESULTS).map(m =>
                `<a href="/${m.i}" class="navbar__result navbar__result-text flex items-center justify-between px-4 py-2.5 gap-3 text-zinc-300 transition-colors duration-100 hover:bg-zinc-800/50"><span class="truncate">${escapeHtml(m.t)}</span>${renderBadge(m.d)}</a>`,
            ).join('');
        }

        el.classList.add('opacity-100', 'pointer-events-auto');
        el.classList.remove('opacity-0', 'pointer-events-none');
    }

    function sortResults(a: SearchEntry, b: SearchEntry): number {
        if (a.d === 'ds' && b.d !== 'ds') return -1;
        if (a.d !== 'ds' && b.d === 'ds') return 1;
        if (a.d !== 'ds' && b.d !== 'ds') return parseInt(a.i) - parseInt(b.i);
        return a.t.localeCompare(b.t);
    }

    function initSearch() {
        if (initialized) return;
        initialized = true;

        const input = document.getElementById('search-input') as HTMLInputElement | null;
        const resultsEl = document.getElementById('search-results') as HTMLElement | null;
        if (!input || !resultsEl) return;
        const results = resultsEl;

        loadIndex();

        async function search(query: string) {
            if (!query) {
                results.classList.remove('opacity-100', 'pointer-events-auto');
                results.classList.add('opacity-0', 'pointer-events-none');
                return;
            }

            const index = await loadIndex();
            const normalizedQuery = query.toLowerCase();
            const matches = index
                .filter(entry => entry.t.toLowerCase().includes(normalizedQuery) || entry.i === normalizedQuery)
                .sort(sortResults);
            renderResults(results, matches);
        }

        input.addEventListener('input', e => search((e.target as HTMLInputElement).value));
        input.addEventListener('focus', () => {
            if (input.value) search(input.value);
        });

        document.addEventListener('click', (e) => {
            const target = e.target as Node;

            if (!input.contains(target) && !results.contains(target)) {
                results.classList.remove('opacity-100', 'pointer-events-auto');
                results.classList.add('opacity-0', 'pointer-events-none');
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === '/') {
                e.preventDefault();
                input.focus();
            }

            if (e.key === 'Escape') {
                input.value = '';
                results.classList.remove('opacity-100', 'pointer-events-auto');
                results.classList.add('opacity-0', 'pointer-events-none');
                input.blur();
            }
        });
    }

    initSearch();
    document.addEventListener('astro:page-load', () => {
        initialized = false;
        initSearch();
    });
</script>
