---
import EventCard from '@components/EventCard.astro';
import EventCardEmpty from '@components/EventCardEmpty.astro';

interface MeetupEvent {
    city: string;
    dateTime: string;
    endTime: string;
    title: string;
    url: string;
    venue: string;
}

async function fetchEvents(): Promise<MeetupEvent[]> {
    try {
        const res = await fetch('https://www.meetup.com/algoatx/events');
        if (!res.ok) throw new Error(`Meetup API ${res.status}`);

        const html = await res.text();
        const match = html.match(/<script id="__NEXT_DATA__"[^>]*>([\s\S]*?)<\/script>/);
        if (!match) return [];

        const data = JSON.parse(match[1]);
        const state = data?.props?.pageProps?.__APOLLO_STATE__;
        if (!state) return [];

        const venues: Record<string, { city: string; name: string }> = {};

        for (const [key, value] of Object.entries(state)) {
            if (key.startsWith('Venue:')) {
                const venueData = value as Record<string, unknown>;
                venues[key] = { city: (venueData.city as string) || '', name: (venueData.name as string) || '' };
            }
        }

        const events: MeetupEvent[] = [];

        for (const [key, value] of Object.entries(state)) {
            if (key.startsWith('Event:')) {
                const eventData = value as Record<string, unknown>;
                const venueRef = (eventData.venue as Record<string, string>)?.__ref || '';
                const venue = venues[venueRef] || { city: '', name: '' };

                events.push({
                    city: venue.city,
                    dateTime: (eventData.dateTime as string) || '',
                    endTime: (eventData.endTime as string) || '',
                    title: (eventData.title as string) || '',
                    url: (eventData.eventUrl as string) || '',
                    venue: venue.name,
                });
            }
        }

        return events.sort((a, b) => new Date(a.dateTime).getTime() - new Date(b.dateTime).getTime());
    } catch (error) {
        console.error('Failed to fetch events:', error);
        return [];
    }
}

const events = await fetchEvents();
---

<section
    class="meetup-events px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)] bg-zinc-950"
    aria-labelledby="events-heading"
>
    <div class="max-w-6xl mx-auto">
        <h2
            id="events-heading"
            class="meetup-events__title mb-[clamp(2rem,calc(0.67rem+6.67vw),6rem)] text-center text-[clamp(1.5rem,calc(1rem+2.5vw),3rem)] uppercase tracking-[0.3em] text-zinc-200/85"
        >
            Events
        </h2>
        <div class="space-y-[clamp(2rem,calc(1.33rem+3.33vw),4rem)]">
            {events.length === 0
                ? <EventCardEmpty />
                : events.slice(0, 5).map(event => (
                        <EventCard
                            city={event.city}
                            dateTime={event.dateTime}
                            endTime={event.endTime}
                            title={event.title}
                            url={event.url}
                            venue={event.venue}
                        />
                    ))}
        </div>
    </div>
</section>

<style is:global>
    .meetup-events__card {
        transition:
            background-color 0.3s cubic-bezier(0.4, 0, 0.2, 1),
            border-color 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .meetup-events__card:hover {
        background-color: rgba(var(--rgb-white), 0.02);
        border-color: rgba(var(--color-indigo), 0.3);
    }

    .meetup-events__card:hover .meetup-events__arrow {
        color: rgba(var(--color-indigo), 0.6);
        transform: translateX(4px);
    }

    .meetup-events__card:hover .meetup-events__day::before {
        opacity: 1;
    }

    .meetup-events__card:hover .meetup-events__name {
        color: rgba(var(--color-indigo), 0.9);
    }

    .meetup-events__day {
        background: linear-gradient(
            180deg,
            rgba(var(--rgb-white), 0.85) 0%,
            rgba(var(--rgb-white), 0.4) 100%
        );
        background-clip: text;
        position: relative;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .meetup-events__day::before {
        background: linear-gradient(
            180deg,
            rgba(var(--color-indigo), 0.9) 0%,
            rgba(var(--color-indigo), 0.4) 100%
        );
        background-clip: text;
        content: attr(data-day);
        inset: 0;
        opacity: 0;
        position: absolute;
        transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .meetup-events__name {
        transition: color 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>
