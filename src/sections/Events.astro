---
interface MeetupEvent {
    attendees: number;
    city: string;
    dateTime: string;
    endTime: string;
    title: string;
    url: string;
    venue: string;
}

async function fetchEvents(): Promise<MeetupEvent[]> {
    try {
        const res = await fetch('https://www.meetup.com/algoatx/events/');
        const html = await res.text();
        const match = html.match(/<script id="__NEXT_DATA__"[^>]*>([\s\S]*?)<\/script>/);
        if (!match) return [];

        const data = JSON.parse(match[1]);
        const state = data?.props?.pageProps?.__APOLLO_STATE__;
        if (!state) return [];

        const venues: Record<string, { city: string; name: string }> = {};
        for (const [key, value] of Object.entries(state)) {
            if (key.startsWith('Venue:')) {
                const v = value as Record<string, unknown>;
                venues[key] = { city: (v.city as string) || '', name: (v.name as string) || '' };
            }
        }

        const events: MeetupEvent[] = [];
        for (const [key, value] of Object.entries(state)) {
            if (key.startsWith('Event:')) {
                const e = value as Record<string, unknown>;
                const venueRef = (e.venue as Record<string, string>)?.__ref || '';
                const venue = venues[venueRef] || { city: '', name: '' };
                events.push({
                    attendees: (e.going as Record<string, number>)?.totalCount || 0,
                    city: venue.city,
                    dateTime: (e.dateTime as string) || '',
                    endTime: (e.endTime as string) || '',
                    title: (e.title as string) || '',
                    url: (e.eventUrl as string) || '',
                    venue: venue.name,
                });
            }
        }

        return events.sort((a, b) => new Date(a.dateTime).getTime() - new Date(b.dateTime).getTime());
    } catch {
        return [];
    }
}

const events = await fetchEvents();

function formatDate(dateStr: string) {
    const date = new Date(dateStr);
    return {
        day: date.getDate(),
        month: date.toLocaleDateString('en-US', { month: 'short' }),
        time: date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }),
        weekday: date.toLocaleDateString('en-US', { weekday: 'short' }),
        year: date.getFullYear(),
    };
}
---

<section
    aria-labelledby="events-heading"
    class="meetup-events bg-zinc-950 px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)]"
>
    <div class="mx-auto max-w-6xl">
        <h2
            class="meetup-events__title mb-[clamp(2rem,calc(0.67rem+6.67vw),6rem)] text-center text-[clamp(1.5rem,calc(1rem+2.5vw),3rem)] uppercase tracking-[0.3em] text-zinc-200/85"
            id="events-heading"
        >
            Events
        </h2>

        <div class="space-y-[clamp(2rem,calc(1rem+5vw),4rem)]">
            {events.length === 0 ? (
            <a
                aria-label="No upcoming events — visit us on Meetup (opens in new tab)"
                class="meetup-events__card group block border border-white/10 p-[clamp(1.5rem,calc(0.67rem+4.17vw),4rem)]"
                data-scroll="up"
                href="https://meetup.com/algoatx"
                rel="noopener noreferrer"
                target="_blank"
            >
                <div class="flex flex-col gap-[clamp(2rem,calc(1rem+5vw),3rem)] md:flex-row md:items-center">
                    <div class="flex shrink-0 flex-col items-center border-white/10 text-center md:w-[clamp(6rem,calc(4.67rem+6.67vw),10rem)] md:border-r md:pr-[clamp(1rem,calc(0.33rem+3.33vw),3rem)]">
                        <span class="meetup-events__day font-bold text-[clamp(2.5rem,calc(1.83rem+3.33vw),4.5rem)] leading-tight">
                            —
                        </span>
                    </div>
                    <div class="min-w-0 flex-1 space-y-[clamp(2rem,calc(1rem+5vw),3rem)] text-center md:text-left md:space-y-[clamp(0.75rem,calc(0.42rem+1.67vw),1.5rem)]">
                        <h3 class="meetup-events__name text-center font-semibold leading-snug text-[clamp(1.25rem,calc(0.92rem+1.67vw),2.25rem)] text-zinc-200 md:text-left">
                            No upcoming events
                        </h3>
                    </div>
                    <span aria-hidden="true" class="meetup-events__arrow hidden shrink-0 select-none text-[clamp(1rem,calc(0.67rem+1.67vw),2rem)] text-zinc-200/30 transition-all duration-300 md:block">→</span>
                </div>
            </a>
            ) : events.slice(0, 5).map((event) => {
                const d = formatDate(event.dateTime);
                return (
                    <a
                        aria-label={`${event.title} — ${d.weekday} ${d.month} ${d.day}, ${d.year} at ${d.time} (opens in new tab)`}
                        class="meetup-events__card group block border border-white/10 p-[clamp(1.5rem,calc(0.67rem+4.17vw),4rem)]"
                        data-scroll="up"
                        href={event.url}
                        rel="noopener noreferrer"
                        target="_blank"
                    >
                        <div class="flex flex-col gap-[clamp(2rem,calc(1rem+5vw),3rem)] md:flex-row md:items-center">
                            <time class="flex shrink-0 flex-col items-center border-white/10 text-center md:w-[clamp(6rem,calc(4.67rem+6.67vw),10rem)] md:border-r md:pr-[clamp(1rem,calc(0.33rem+3.33vw),3rem)]" datetime={event.dateTime}>
                                <span class="text-[clamp(0.625rem,calc(0.54rem+0.42vw),0.875rem)] uppercase tracking-[0.2em] text-zinc-200/80">
                                    {d.weekday}
                                </span>
                                <span class="meetup-events__day font-bold text-[clamp(2.5rem,calc(1.83rem+3.33vw),4.5rem)] leading-tight">
                                    {d.day}
                                </span>
                                <span class="text-[clamp(0.75rem,calc(0.67rem+0.42vw),1rem)] uppercase tracking-[0.15em] text-zinc-200/90">
                                    {d.month} {d.year}
                                </span>
                            </time>

                            <div class="min-w-0 flex-1 space-y-[clamp(2rem,calc(1rem+5vw),3rem)] text-center md:text-left md:space-y-[clamp(0.75rem,calc(0.42rem+1.67vw),1.5rem)]">
                                <h3 class="meetup-events__name text-center font-semibold leading-snug text-[clamp(1.25rem,calc(0.92rem+1.67vw),2.25rem)] text-zinc-200 md:text-left">
                                    {event.title}
                                </h3>
                                <div class="text-[clamp(0.875rem,calc(0.79rem+0.42vw),1.125rem)] text-zinc-200/80">
                                    <p><span aria-hidden="true">🕐</span>&ensp;<span class="sr-only">Time: </span>{d.time} – {formatDate(event.endTime).time}</p>
                                    <p class="mt-[clamp(0.75rem,calc(0.42rem+1.67vw),1.5rem)]"><span aria-hidden="true">📍</span>&ensp;<span class="sr-only">Location: </span>{event.venue}{event.city && `, ${event.city}`}</p>
                                </div>
                            </div>

                            <span aria-hidden="true" class="meetup-events__arrow hidden shrink-0 select-none text-[clamp(1rem,calc(0.67rem+1.67vw),2rem)] text-zinc-200/30 transition-all duration-300 md:block">→</span>
                        </div>
                    </a>
                );
            })}
        </div>

    </div>
</section>

<style>
    .meetup-events__card {
        transition:
            background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1),
            border-color 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .meetup-events__card:hover {
        background-color: rgba(255, 255, 255, 0.02);
        border-color: rgba(var(--color-indigo), 0.3);
    }

    .meetup-events__card:hover .meetup-events__arrow {
        color: rgba(var(--color-indigo), 0.6);
        transform: translateX(4px);
    }

    .meetup-events__card:hover .meetup-events__day {
        background: linear-gradient(
            180deg,
            rgba(var(--color-indigo), 0.9) 0%,
            rgba(var(--color-indigo), 0.4) 100%
        );
        background-clip: text;
    }

    .meetup-events__card:hover .meetup-events__name {
        color: rgba(var(--color-indigo), 0.9);
    }

    .meetup-events__day {
        -webkit-text-fill-color: transparent;
        background: linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.85) 0%,
            rgba(255, 255, 255, 0.4) 100%
        );
        background-clip: text;
    }
</style>
