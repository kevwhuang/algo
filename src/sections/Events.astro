---
interface MeetupEvent {
    attendees: number;
    city: string;
    dateTime: string;
    endTime: string;
    title: string;
    url: string;
    venue: string;
}

// TODO: Replace mock data with Meetup API fetch
// Parse from: https://www.meetup.com/MEETUP_GROUP/events/
// Event data lives in __NEXT_DATA__ > props > pageProps > __APOLLO_STATE__
// Keys: Event:*, Venue:* — fields: title, dateTime, endTime, eventUrl, going.totalCount, venue.__ref

const events: MeetupEvent[] = [
    {
        attendees: 0,
        city: 'Austin',
        dateTime: '2026-04-05T14:00:00-05:00',
        endTime: '2026-04-05T17:00:00-05:00',
        title: 'Graph Traversal Workshop',
        url: 'https://www.google.com/search?q=graph+traversal+workshop',
        venue: 'Downtown Library',
    },
    {
        attendees: 0,
        city: 'San Francisco Bay Area, California',
        dateTime: '2026-12-31T23:59:00-05:00',
        endTime: '2027-01-01T06:00:00-05:00',
        title: 'End of Year Showcase & Collaborative Production Marathon with Special Guest Producers from Around the World',
        url: 'https://www.google.com/search?q=end+of+year+showcase',
        venue: 'Austin Convention Center & Exhibition Hall — Grand Ballroom West Wing',
    },
    {
        attendees: 0,
        city: 'Austin',
        dateTime: '2026-04-19T10:00:00-05:00',
        endTime: '2026-04-19T12:30:00-05:00',
        title: 'Mock Interview Practice',
        url: 'https://www.google.com/search?q=mock+interview+practice',
        venue: 'ACC Highland Campus',
    },
];

function formatDate(dateStr: string) {
    const date = new Date(dateStr);
    return {
        day: date.getDate(),
        month: date.toLocaleDateString('en-US', { month: 'short' }),
        time: date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }),
        weekday: date.toLocaleDateString('en-US', { weekday: 'short' }),
        year: date.getFullYear(),
    };
}
---

<section
    class="meetup-events bg-zinc-950 px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)]"
>
    <div class="mx-auto max-w-6xl">
        <h2
            class="meetup-events__title mb-[clamp(2rem,calc(0.67rem+6.67vw),6rem)] text-center text-[clamp(1.5rem,calc(1rem+2.5vw),3rem)] uppercase tracking-[0.3em] text-zinc-200/70"
        >
            Events
        </h2>

        <div class="space-y-[clamp(2rem,calc(1rem+5vw),4rem)]">
            <a
                aria-label="No upcoming events — visit us on Meetup (opens in new tab)"
                class="meetup-events__card group block border border-white/10 p-[clamp(1.5rem,calc(0.67rem+4.17vw),4rem)] transition-all duration-300"
                href="https://www.google.com/search?q=upcoming+events"
                rel="noopener noreferrer"
                target="_blank"
            >
                <div class="flex flex-col gap-[clamp(2rem,calc(1rem+5vw),3rem)] md:flex-row md:items-center">
                    <div class="flex shrink-0 flex-col items-center border-white/10 text-center md:w-[clamp(6rem,calc(4.67rem+6.67vw),10rem)] md:border-r md:pr-[clamp(1rem,calc(0.33rem+3.33vw),3rem)]">
                        <span class="meetup-events__day font-bold text-[clamp(2.5rem,calc(1.83rem+3.33vw),4.5rem)] leading-tight">
                            —
                        </span>
                    </div>
                    <div class="min-w-0 flex-1 space-y-[clamp(0.75rem,calc(0.42rem+1.67vw),1.5rem)]">
                        <h3 class="meetup-events__name font-semibold leading-snug text-[clamp(1.25rem,calc(0.92rem+1.67vw),2.25rem)] text-zinc-200">
                            No upcoming events
                        </h3>
                        <p class="text-[clamp(0.875rem,calc(0.79rem+0.42vw),1.125rem)] text-zinc-200/80">
                            Check back soon or visit us on Meetup
                        </p>
                    </div>
                    <span aria-hidden="true" class="meetup-events__arrow hidden shrink-0 text-[clamp(1rem,calc(0.67rem+1.67vw),2rem)] text-zinc-200/30 transition-all duration-300 md:block">→</span>
                </div>
            </a>
            {events.map((event) => {
                const d = formatDate(event.dateTime);
                return (
                    <a
                        aria-label={`${event.title} — ${d.weekday} ${d.month} ${d.day}, ${d.year} at ${d.time} (opens in new tab)`}
                        class="meetup-events__card group block border border-white/10 p-[clamp(1.5rem,calc(0.67rem+4.17vw),4rem)] transition-all duration-300"
                        href={event.url}
                        rel="noopener noreferrer"
                        target="_blank"
                    >
                        <div class="flex flex-col gap-[clamp(2rem,calc(1rem+5vw),3rem)] md:flex-row md:items-center">
                            <div class="flex shrink-0 flex-col items-center border-white/10 text-center md:w-[clamp(6rem,calc(4.67rem+6.67vw),10rem)] md:border-r md:pr-[clamp(1rem,calc(0.33rem+3.33vw),3rem)]">
                                <span class="text-[clamp(0.625rem,calc(0.54rem+0.42vw),0.875rem)] uppercase tracking-[0.2em] text-zinc-200/80">
                                    {d.weekday}
                                </span>
                                <span class="meetup-events__day font-bold text-[clamp(2.5rem,calc(1.83rem+3.33vw),4.5rem)] leading-tight">
                                    {d.day}
                                </span>
                                <span class="text-[clamp(0.75rem,calc(0.67rem+0.42vw),1rem)] uppercase tracking-[0.15em] text-zinc-200/90">
                                    {d.month} {d.year}
                                </span>
                            </div>

                            <div class="min-w-0 flex-1 space-y-[clamp(0.75rem,calc(0.42rem+1.67vw),1.5rem)]">
                                <h3 class="meetup-events__name font-semibold leading-snug text-[clamp(1.25rem,calc(0.92rem+1.67vw),2.25rem)] text-zinc-200">
                                    {event.title}
                                </h3>
                                <p class="flex flex-wrap items-center gap-x-[clamp(0.5rem,calc(0.33rem+0.83vw),1rem)] gap-y-1 text-[clamp(0.875rem,calc(0.79rem+0.42vw),1.125rem)] text-zinc-200/80">
                                    <span><span aria-hidden="true">🕐</span> {d.time} – {formatDate(event.endTime).time}</span>
                                    <span class="flex items-center gap-1.5">
                                        <span aria-hidden="true">📍</span>
                                        {event.venue}{event.city && `, ${event.city}`}
                                    </span>
                                </p>
                            </div>

                            <span aria-hidden="true" class="meetup-events__arrow hidden shrink-0 text-[clamp(1rem,calc(0.67rem+1.67vw),2rem)] text-zinc-200/30 transition-all duration-300 md:block">→</span>
                        </div>
                    </a>
                );
            })}
        </div>
    </div>
</section>

<style>
    .meetup-events__card:hover {
        background-color: rgba(255, 255, 255, 0.02);
        border-color: rgba(var(--color-indigo), 0.3);
    }

    .meetup-events__card:hover .meetup-events__arrow {
        color: rgba(var(--color-indigo), 0.6);
        transform: translateX(4px);
    }

    .meetup-events__card:hover .meetup-events__day {
        background: linear-gradient(
            180deg,
            rgba(var(--color-indigo), 0.9) 0%,
            rgba(var(--color-indigo), 0.4) 100%
        );
        background-clip: text;
    }

    .meetup-events__card:hover .meetup-events__name {
        color: rgba(var(--color-indigo), 0.9);
    }

    .meetup-events__day {
        -webkit-text-fill-color: transparent;
        background: linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.85) 0%,
            rgba(255, 255, 255, 0.4) 100%
        );
        background-clip: text;
    }
</style>
