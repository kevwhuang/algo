---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-zinc-950">
    <div class="mx-auto max-w-7xl px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)]">
        <p class="text-center text-[clamp(0.75rem,calc(0.67rem+0.42vw),1rem)] text-zinc-500">
            &copy; {year} <a class="underline underline-offset-2 transition-colors duration-300 hover:text-indigo-400" href="https://aephonics.com">Aephonics</a>. All rights reserved.
        </p>
    </div>
</footer>
