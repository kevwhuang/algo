---
import fs from 'node:fs';
import path from 'node:path';

interface DifficultyStats {
    completed: number;
    cssVar: string;
    label: string;
    total: number;
}

function countCompleted(dir: string): { completed: number; total: number } {
    let completed = 0;
    let total = 0;
    for (const sub of fs.readdirSync(dir)) {
        const subDir = path.join(dir, sub);
        if (!fs.statSync(subDir).isDirectory() || sub === 'front-end') continue;
        for (const file of fs.readdirSync(subDir)) {
            if (file.startsWith('.')) continue;
            total++;
            const lines = fs.readFileSync(path.join(subDir, file), 'utf-8').trim().split('\n');
            if (lines.length >= 3) completed++;
        }
    }
    return { completed, total };
}

const stats: DifficultyStats[] = [
    {
        cssVar: 'var(--color-easy)',
        label: 'Easy',
        ...countCompleted('src/content/easy'),
    },
    {
        cssVar: 'var(--color-medium)',
        label: 'Medium',
        ...countCompleted('src/content/medium'),
    },
    {
        cssVar: 'var(--color-hard)',
        label: 'Hard',
        ...countCompleted('src/content/hard'),
    },
];
---

<section class="bg-zinc-950 px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)]">
    <div class="mx-auto max-w-6xl">
        <h2 class="mb-[clamp(2rem,calc(0.67rem+6.67vw),6rem)] text-center text-[clamp(1.5rem,calc(1rem+2.5vw),3rem)] uppercase tracking-[0.3em] text-zinc-200/85">
            Progress
        </h2>

        <div class="space-y-[clamp(2rem,calc(1.33rem+3.33vw),3.5rem)]">
            {stats.map(({ completed, cssVar, label, total }) => {
                const pct = total > 0 ? Math.round((completed / total) * 100) : 0;
                return (
                    <div>
                        <div class="mb-[clamp(0.5rem,calc(0.33rem+0.83vw),1rem)] flex items-baseline justify-between">
                            <span class="font-semibold text-[clamp(1.125rem,calc(0.79rem+1.67vw),2.125rem)]" style={`color: rgb(${cssVar})`}>
                                {label}
                            </span>
                            <span class="font-mono text-[clamp(0.875rem,calc(0.71rem+0.83vw),1.375rem)]">
                                {completed}<span class="text-zinc-500">/{total}</span>
                            </span>
                        </div>
                        <div
                            aria-label={`${label} progress`}
                            aria-valuemax={total}
                            aria-valuemin={0}
                            aria-valuenow={completed}
                            class="h-[clamp(0.625rem,calc(0.46rem+0.83vw),1.125rem)] overflow-hidden rounded-full"
                            role="progressbar"
                            style={`background: rgba(${cssVar}, 0.15)`}
                        >
                            <div
                                class="progress__bar h-full rounded-full"
                                data-width={pct}
                                style={`width: 0%; background: linear-gradient(90deg, rgb(${cssVar}), color-mix(in srgb, rgb(${cssVar}) 70%, white)); box-shadow: 0 0 12px rgba(${cssVar}, 0.15)`}
                            />
                        </div>
                    </div>
                );
            })}
        </div>
    </div>
</section>

<style>
    .progress__bar {
        transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>

<script>
    function animateBars() {
        const bars = document.querySelectorAll<HTMLElement>('.progress__bar');
        const observer = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    if (entry.isIntersecting) {
                        const bar = entry.target as HTMLElement;
                        setTimeout(() => {
                            bar.style.width = `${bar.dataset.width}%`;
                        }, 1000);
                        observer.unobserve(bar);
                    }
                }
            },
            { threshold: 0.2 },
        );
        for (const bar of bars) {
            bar.style.width = '0%';
            observer.observe(bar);
        }
    }

    animateBars();
    document.addEventListener('astro:page-load', animateBars);
</script>
