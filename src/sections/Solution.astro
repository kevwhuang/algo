---
import { Code } from 'astro:components';

import type { ComponentProps } from 'astro/types';

type CodeLang = ComponentProps<typeof Code>['lang'];

interface Props {
    code: string;
    difficulty?: string;
    lang: string;
    langLabel: string;
    title: string;
}

const { code: rawCode, difficulty, lang, langLabel, title } = Astro.props;
const code = rawCode.endsWith('\n') ? rawCode + ' ' : rawCode;

const difficultyColor = {
    easy: 'bg-emerald-500/15 text-emerald-400',
    hard: 'bg-red-500/15 text-red-400',
    medium: 'bg-amber-500/15 text-amber-400',
}[difficulty ?? ''] ?? '';
---

<section class="px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)] bg-zinc-950" aria-labelledby="solution-heading">
    <div class="max-w-6xl mx-auto">
        <h1 id="solution-heading" class="solution__title mb-[clamp(1.5rem,calc(0.83rem+3.33vw),3rem)] font-bold text-[clamp(1.5rem,calc(0.83rem+3.33vw),3rem)] leading-tight text-zinc-100">
            {title}
        </h1>
        <div class="solution__code group relative rounded-lg border border-zinc-800 overflow-hidden" aria-label={`${title} source code`} role="region">
            <div class="flex items-center justify-between px-[clamp(0.75rem,calc(0.5rem+1.25vw),1.5rem)] py-[clamp(0.5rem,calc(0.33rem+0.83vw),1rem)] border-b border-zinc-800 bg-zinc-900/80">
                <div class="flex flex-wrap gap-[clamp(0.5rem,calc(0.33rem+0.83vw),1rem)]">
                    <span class="inline-block px-3 py-1 rounded-full font-mono text-[clamp(0.75rem,calc(0.67rem+0.42vw),1rem)] tracking-[0.1em] bg-indigo-500/15 text-indigo-400">
                        {langLabel}
                    </span>
                    {difficulty && (
                        <span class={`inline-block px-3 py-1 rounded-full font-mono text-[clamp(0.75rem,calc(0.67rem+0.42vw),1rem)] tracking-[0.1em] ${difficultyColor}`}>
                            {difficulty[0].toUpperCase() + difficulty.slice(1)}
                        </span>
                    )}
                </div>
                <button
                    class="solution__copy hidden min-w-16 px-3 py-1 rounded font-mono text-[clamp(0.75rem,calc(0.67rem+0.42vw),1rem)] text-center text-zinc-500 transition-all duration-300 cursor-pointer sm:inline-block"
                    aria-label="Copy code"
                    data-code={code}
                    type="button"
                >
                    Copy
                </button>
            </div>
            <div class="solution__highlight overflow-x-auto" aria-hidden="true">
                <Code code={code} lang={lang as CodeLang} theme="github-dark-default" />
            </div>
            <pre class="sr-only"><code>{code}</code></pre>
            <div id="copy-status" class="sr-only" aria-live="polite"></div>
        </div>
    </div>
</section>

<style>
    .solution__highlight {
        background: rgb(var(--rgb-code-bg));
    }

    .solution__copy:hover {
        color: rgba(var(--color-indigo), 0.9);
    }

    .solution__highlight :global(code) {
        background: transparent !important;
        counter-reset: line;
        display: block;
        font-size: clamp(0.75rem, calc(0.67rem + 0.42vw), 1rem);
        line-height: 1.75;
    }

    .solution__highlight :global(pre) {
        background: transparent !important;
        margin: 0;
        padding: clamp(0.75rem, calc(0.5rem + 1.25vw), 1.5rem);
    }

    .solution__highlight :global(.line) {
        counter-increment: line;
    }

    .solution__highlight :global(.line::before) {
        color: rgb(var(--rgb-zinc-600));
        content: counter(line);
        display: inline-block;
        margin-right: clamp(0.75rem, calc(0.5rem + 1.25vw), 1.5rem);
        text-align: right;
        user-select: none;
        width: 3ch;
    }

    .solution__highlight :global(::selection) {
        background: rgba(var(--color-indigo), 0.5);
    }
</style>

<script>
    const COPY_RESET_DELAY = 2000;
    const FADE_DURATION = 200;

    let fadeTimer = 0;
    let resetTimer = 0;

    function fadeText(button: HTMLButtonElement, text: string, label: string) {
        clearTimeout(fadeTimer);
        button.style.opacity = '0';

        fadeTimer = window.setTimeout(() => {
            button.textContent = text;
            button.setAttribute('aria-label', label);
            button.style.opacity = '1';
        }, FADE_DURATION);
    }

    function initCopy() {
        for (const button of document.querySelectorAll<HTMLButtonElement>('.solution__copy')) {
            button.addEventListener('click', async () => {
                const code = button.dataset.code ?? '';
                const status = document.getElementById('copy-status');

                clearTimeout(resetTimer);

                try {
                    await navigator.clipboard.writeText(code);
                    fadeText(button, 'Copied!', 'Code copied to clipboard');
                    if (status) status.textContent = 'Code copied to clipboard';
                } catch {
                    fadeText(button, 'Failed', 'Failed to copy code');
                    if (status) status.textContent = 'Failed to copy code';
                }

                resetTimer = window.setTimeout(() => {
                    fadeText(button, 'Copy', 'Copy code');
                    if (status) status.textContent = '';
                }, COPY_RESET_DELAY);
            });
        }
    }

    function removePrefocus() {
        for (const pre of document.querySelectorAll('.solution__highlight pre')) {
            pre.removeAttribute('tabindex');
        }
    }

    document.addEventListener('astro:page-load', () => {
        initCopy();
        removePrefocus();
    });
</script>
