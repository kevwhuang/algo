---
import { Code } from 'astro:components';

import type { ComponentProps } from 'astro/types';

type CodeLang = ComponentProps<typeof Code>['lang'];

interface Props {
    code: string;
    difficulty?: string;
    lang: string;
    langLabel: string;
    title: string;
}

const { code: rawCode, difficulty, lang, langLabel, title } = Astro.props;
const code = rawCode.endsWith('\n') ? rawCode + ' ' : rawCode;

const difficultyColor = {
    easy: 'bg-emerald-500/15 text-emerald-400',
    hard: 'bg-red-500/15 text-red-400',
    medium: 'bg-amber-500/15 text-amber-400',
}[difficulty ?? ''] ?? '';
---

<section class="px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)] bg-zinc-950" aria-labelledby="content-heading">
    <div class="max-w-6xl mx-auto">
        <h1 id="content-heading" class="content__title mb-[clamp(1.5rem,calc(0.83rem+3.33vw),3rem)] font-bold text-[clamp(1.5rem,calc(0.83rem+3.33vw),3rem)] leading-tight text-zinc-100">
            {title}
        </h1>

        <div class="content__code group relative rounded-lg border border-zinc-800 overflow-hidden" aria-label={`${title} source code`} role="region">
            <div class="flex items-center justify-between px-[clamp(0.75rem,calc(0.5rem+1.25vw),1.5rem)] py-[clamp(0.5rem,calc(0.33rem+0.83vw),1rem)] border-b border-zinc-800 bg-zinc-900/80">
                <div class="flex flex-wrap gap-3">
                    <span class="inline-block px-2.5 py-0.5 rounded-full font-mono text-[clamp(0.625rem,calc(0.54rem+0.42vw),0.75rem)] tracking-[0.1em] text-indigo-400 bg-indigo-500/15">
                        {langLabel}
                    </span>
                    {difficulty && (
                        <span class={`inline-block px-2.5 py-0.5 rounded-full font-mono text-[clamp(0.625rem,calc(0.54rem+0.42vw),0.75rem)] tracking-[0.1em] ${difficultyColor}`}>
                            {difficulty[0].toUpperCase() + difficulty.slice(1)}
                        </span>
                    )}
                </div>
                <button
                    class="content__copy px-2 py-1 rounded font-mono text-[clamp(0.625rem,calc(0.54rem+0.42vw),0.875rem)] text-zinc-500 transition-colors duration-300 cursor-pointer"
                    aria-label="Copy code"
                    data-code={code}
                    type="button"
                >
                    Copy
                </button>
            </div>
            <div class="content__highlight overflow-x-auto">
                <Code code={code} lang={lang as CodeLang} theme="github-dark-default" />
            </div>
        </div>
    </div>
</section>

<style>
    .content__highlight {
        background: rgb(14 14 18);
    }

    .content__copy:hover {
        color: rgba(var(--color-indigo), 0.9);
    }

    .content__highlight :global(pre) {
        background: transparent !important;
        margin: 0;
        padding: clamp(0.75rem, calc(0.5rem + 1.25vw), 1.5rem);
    }

    .content__highlight :global(code) {
        background: transparent !important;
        counter-reset: line;
        display: block;
        font-size: clamp(0.75rem, calc(0.67rem + 0.42vw), 1rem);
        line-height: 1.75;
    }

    .content__highlight :global(.line) {
        counter-increment: line;
        display: inline-block;
        width: 100%;
    }

    .content__highlight :global(.line::before) {
        color: rgb(63 63 70);
        content: counter(line);
        display: inline-block;
        margin-right: clamp(0.75rem, calc(0.5rem + 1.25vw), 1.5rem);
        text-align: right;
        user-select: none;
        width: 2ch;
    }
</style>

<script>
    const COPY_RESET_DELAY = 2000;

    function initCopy() {
        for (const btn of document.querySelectorAll<HTMLButtonElement>('.content__copy')) {
            btn.addEventListener('click', async () => {
                const code = btn.dataset.code ?? '';

                try {
                    await navigator.clipboard.writeText(code);
                    btn.textContent = 'Copied!';
                } catch {
                    btn.textContent = 'Failed';
                }

                setTimeout(() => {
                    btn.textContent = 'Copy';
                }, COPY_RESET_DELAY);
            });
        }
    }

    initCopy();
    document.addEventListener('astro:page-load', initCopy);
</script>
