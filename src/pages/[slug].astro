---
import { getCollection } from 'astro:content';

import Base from '@layouts/Base.astro';
import Solution from '@sections/Solution.astro';

interface Props {
    code: string;
    difficulty?: string;
    lang: string;
    langLabel: string;
    title: string;
}

const { code, difficulty, lang, langLabel, title } = Astro.props;

export async function getStaticPaths() {
    const [dataStructures, problems] = await Promise.all([
        getCollection('dataStructures'),
        getCollection('problems'),
    ]);

    return [
        ...dataStructures.map(entry => ({
            params: { slug: entry.id },
            props: { ...entry.data },
        })),
        ...problems.map(entry => ({
            params: { slug: entry.id },
            props: { ...entry.data, difficulty: entry.data.difficulty },
        })),
    ];
}
---

<Base
    description={`${title} — algorithm solution and implementation`}
    title={`${title} | Algo`}
>
    <Solution code={code} difficulty={difficulty} lang={lang} langLabel={langLabel} title={title} />
</Base>
