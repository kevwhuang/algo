---
import '@fontsource/geist-sans';
import { ClientRouter } from 'astro:transitions';

import Footer from '@sections/Footer.astro';
import Navbar from '@sections/Navbar.astro';

interface Props {
    description: string;
    title: string;
}

const { description, title } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1" name="viewport" />
        <title>{title}</title>
        <meta content="Kevin Huang" name="author" />
        <meta content={description} name="description" />
        <meta content="#09090b" name="theme-color" />
        <link href={canonicalUrl} rel="canonical" />
        <link href="/favicon.svg" rel="icon" type="image/svg+xml" />
        <meta content={title} property="og:title" />
        <meta content={description} property="og:description" />
        <meta content={canonicalUrl} property="og:url" />
        <meta content="website" property="og:type" />
        <meta content={`${Astro.site}og.png`} property="og:image" />
        <meta content="algo" property="og:site_name" />
        <meta content="summary_large_image" name="twitter:card" />
        <meta content={title} name="twitter:title" />
        <meta content={description} name="twitter:description" />
        <meta content={`${Astro.site}og.png`} name="twitter:image" />
        <script
            set:html={JSON.stringify({
                '@context': 'https://schema.org',
                '@type': 'WebSite',
                'founder': {
                    '@type': 'Person',
                    'name': 'Kevin Huang',
                },
                'name': 'Algo',
                'url': Astro.site,
            })}
            type="application/ld+json"
        />
        <ClientRouter />
    </head>
    <body class="flex flex-col min-h-screen font-sans bg-zinc-950 text-white">
        <Navbar />
        <main class="flex flex-1 flex-col">
            <slot />
        </main>
        <Footer />
    </body>
</html>

<style is:global>
    @import 'tailwindcss';

    :root {
        --color-code-bg: 14, 14, 18;
        --color-easy: 52, 211, 153;
        --color-hard: 248, 113, 113;
        --color-indigo: 99, 102, 241;
        --color-medium: 251, 191, 36;
        --color-white: 255, 255, 255;
        --color-zinc-600: 63, 63, 70;
        --color-zinc-900: 24, 24, 27;
        --font-sans: 'Geist', system-ui, sans-serif;
    }

    :focus {
        outline: none;
    }

    :focus-visible {
        border-radius: 2px;
        outline: 2px solid rgba(var(--color-indigo), 0.8);
        outline-offset: 2px;
    }

    [data-scroll] {
        opacity: 0;
    }

    @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            scroll-behavior: auto !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>

<script>
    import { initScrollAnimations } from '@lib/scroll';

    initScrollAnimations();
    document.addEventListener('astro:page-load', initScrollAnimations);
</script>
